{
    "latex-workshop.latex.recipes": [
        {
            "name": "latexmk 🔃",
            "tools": [
                "latexmk"
            ]
        }
    ],
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-pdf",
                "-outdir=logs",
                "%DOC%"
            ],
            "env": {}
        }
    ],
    "latex-workshop.latex.rootFile.indicator": "main.tex",
    "latex-workshop.latex.rootFile.doNotPrompt": true,
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.latex.clean.subfolder.enabled": true,
    "latex-workshop.latex.outputDir": "logs",
    "pasteImage.path": "${projectRoot}/imatges",
    "pasteImage.prefix": "img_",
    "pasteImage.forceUserConfig": true,
    "pasteImage.insertPattern": "\\begin{figure}[htbp]\n    \\centering\n    \\includegraphics[width=0.8\\textwidth]{imatges/${imageFileName}}\n    \\caption{Descripció de la imatge}\n    \\label{fig:${imageFileNameWithoutExt}}\n\\end{figure}",
    "editor.tabCompletion": "on",
    "editor.snippetSuggestions": "top",
    "[latex]": {
        "editor.snippetsPreventQuickSuggestions": false,
        "editor.suggestSelection": "recentlyUsed",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        }
    }
}
